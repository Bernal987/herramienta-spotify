<article style="position:relative; background:#181818; color:#ffffff; border-radius:14px; padding:16px; margin-bottom:20px; box-shadow:0 6px 15px rgba(0,0,0,0.5); transition:0.3s; transform:scale(1);" onmouseover="this.style.transform='scale(1.03)'" onmouseout="this.style.transform='scale(1)'">

  <!-- PORTADA -->
  <div style="margin-bottom:12px;">
    {{ content.field_portada }}
    <div style="position:absolute; bottom:20px; right:20px; background:#1db954; width:40px; height:40px; display:flex; align-items:center; justify-content:center; border-radius:50%; font-size:18px;">
      ▶
    </div>
  </div>

  <!-- GENERO Y DURACION -->
  <div style="display:flex; justify-content:space-between; font-size:12px; color:#1db954; margin-bottom:8px;">
    <div>{{ content.field_genero }}</div>
    <div>{{ content.field_duracion }}</div>
  </div>

  <!-- TITULO -->
  <h2 style="font-size:20px; font-weight:bold; margin-bottom:6px;">
    {{ label }}
  </h2>

  <!-- DESTACADO -->
  {% if node.field_destacado.value %}
    <div style="margin-bottom:6px;">
      <span style="background:#1db954; color:#000; font-size:11px; padding:3px 8px; border-radius:12px;">
        Destacado
      </span>
    </div>
  {% endif %}

  <!-- ARTISTA -->
  <div style="color:#b3b3b3; font-size:14px; margin-bottom:4px;">
    {{ content.field_artista_ref }}
  </div>

  <!-- FECHA -->
  <div style="font-size:12px; color:#888; margin-top:4px;">
    {{ content.field_fecha_de_lanzamiento }}
  </div>

  <!-- AUDIO -->
  {% if content.field_audio %}
    <div style="margin-top:10px;">
      {{ content.field_audio }}
    </div>
  {% endif %}

  <!-- FAVORITO -->
  {% if logged_in %}
    <div
      class="btn-fav"
      data-node-id="{{ node.id() }}"
      style="position:absolute; top:10px; right:10px; font-size:18px; cursor:pointer;">
      <span class="fav-icon">🤍</span>
    </div>
  {% endif %}

</article>

<style>
  .btn-fav.activo .fav-icon {
    color: red;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function () {

    document.querySelectorAll('.btn-fav').forEach(btn => {

      btn.addEventListener('click', function () {

        const nodeId = this.dataset.nodeId;

        fetch('/favorito/' + nodeId, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          }
        })
          .then(res => res.json())
          .then(data => {

            if (data.estado === 'ok') {
              this.classList.toggle('activo');
              this.querySelector('.fav-icon').textContent =
                this.classList.contains('activo') ? '❤️' : '🤍';
            }

          });

      });

    });

  });
</script>
