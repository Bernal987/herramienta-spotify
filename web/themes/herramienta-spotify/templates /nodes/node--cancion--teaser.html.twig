{%
  set imagen_cancion = node.field_image.entity.fileuri is not empty
    ? node.field_image.entity.fileuri | image_style('thumbnail')
    : ''
%}

<article class="cancion-card">

  {# Enlace stretched: cubre toda la card #}
  <a href="{{ url }}" class="cancion-card__link" tabindex="-1" aria-hidden="true"></a>

  {# Imagen izquierda #}
  <div class="cancion-card__imagen">
    {% if imagen_cancion %}
      <img src="{{ imagen_cancion }}" alt="{{ label }}" loading="lazy" />
    {% else %}
      <div class="cancion-card__imagen-placeholder">
        <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <rect width="48" height="48" rx="4" fill="#282828"/>
          <path d="M32 16H20a2 2 0 0 0-2 2v10.586A3.5 3.5 0 1 0 21 32V22h9v6.586A3.5 3.5 0 1 0 33 32V18a2 2 0 0 0-1-1.732V16z" fill="#535353"/>
        </svg>
      </div>
    {% endif %}
    <div class="cancion-card__play-btn" aria-hidden="true">▶</div>
  </div>

  {# Contenido derecho #}
  <div class="cancion-card__body">

    <div class="cancion-card__meta">
      <span class="cancion-card__genero">{{ content.field_genero }}</span>
      <span class="cancion-card__duracion">{{ content.field_duracion }}</span>
    </div>

    <h2 class="cancion-card__titulo">
      <a href="{{ url }}">{{ label }}</a>
    </h2>

    {% if node.field_destacado.value %}
      <span class="cancion-card__destacado">Destacado</span>
    {% endif %}

    <div class="cancion-card__artista">{{ content.field_artista_ref }}</div>

    <div class="cancion-card__fecha">{{ content.field_fecha_de_lanzamiento }}</div>

    {% if content.field_audio %}
      <div class="cancion-card__audio">{{ content.field_audio }}</div>
    {% endif %}

  </div>

  {# Botón favorito (sobre el stretched link) #}
  {% if logged_in %}
    <div class="btn-fav cancion-card__fav{{ is_favorito ? ' is-favorito' : '' }}"
         data-node-id="{{ node.id() }}"
         aria-label="{{ is_favorito ? 'Quitar de favoritos' : 'Añadir a favoritos' }}"
         role="button"
         tabindex="0">
      <span class="fav-icon">{{ is_favorito ? '❤️' : '🤍' }}</span>
    </div>
  {% endif %}

</article>
