<div class="playlist-card">

  <div class="playlist-img">
    {{ content.field_image }}
  </div>

  <div class="playlist-info">
    <h3>{{ label }}</h3>
    <div class="playlist-desc">
      {{ content.body }}
    </div>
  </div>

  {# Botón favorito #}
  {% if logged_in %}
    <div class="btn-fav playlist-card__fav{{ is_favorito ? ' is-favorito' : '' }}"
         data-node-id="{{ node.id() }}"
         aria-label="{{ is_favorito ? 'Quitar de favoritos' : 'Añadir a favoritos' }}"
         role="button"
         tabindex="0">
      <span class="fav-icon">{{ is_favorito ? '❤️' : '🤍' }}</span>
    </div>
  {% endif %}

</div>
