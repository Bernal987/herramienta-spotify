<div class="artista">

  {% if content.field_imagen %}
    <div class="artista-imagen">
      {{ content.field_imagen }}
    </div>
  {% endif %}

  <div class="artista-info">
    <h3 class="artista-nombre">
      {{ label }}
    </h3>

    <div class="artista-genero">
      {{ content.field_genero }}
    </div>
  </div>

  {# Botón favorito #}
  {% if logged_in %}
    <div class="btn-fav artista__fav{{ is_favorito ? ' is-favorito' : '' }}"
         data-node-id="{{ node.id() }}"
         aria-label="{{ is_favorito ? 'Quitar de favoritos' : 'Añadir a favoritos' }}"
         role="button"
         tabindex="0">
      <span class="fav-icon">{{ is_favorito ? '❤️' : '🤍' }}</span>
    </div>
  {% endif %}

</div>
